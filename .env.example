# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains your real API key.

# ── Required ───────────────────────────────────────────────────────────────────

# Your OpenRouter API key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Optional ───────────────────────────────────────────────────────────────────

# Activate compliance policy packs (comma-separated)
# Options: owasp-top10, pci-dss, soc2, strict, test-env
# Example: POLICY_PACK=owasp-top10,strict
POLICY_PACK=

# Set to true if running behind a trusted reverse proxy (Nginx, Caddy, etc.)
# This enables correct IP-based rate limiting using X-Forwarded-For headers
TRUST_PROXY=false
