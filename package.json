{
  "name": "ai-code-review",
  "version": "1.4.1",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:safe": "next dev --no-experimental-https-server",
    "electron": "electron .",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "diff": "^5.2.0",
    "framer-motion": "^11.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "openai": "^4.52.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.19",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.shreyashhu.aicodereviewer",
    "productName": "AI Code Reviewer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon-512.png"
    },
    "files": [
      "electron.js",
      "public/**/*"
    ]
  }
}
