# Anthropic API key (get yours at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenRouter fallback (used if Anthropic key missing)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Set to true ONLY when deployed behind a proxy (Vercel, Cloudflare) that
# strips attacker-injected X-Forwarded-For headers.
TRUST_PROXY=false
